# Configurações da Aplicação
APP_NAME="Sistema de Gestão Financeira"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Configurações do Banco de Dados
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=financeiro
DB_USERNAME=root
DB_PASSWORD=

# Configurações JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Configurações de Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_ENCRYPTION=tls
FROM_EMAIL=noreply@financeiro.com
FROM_NAME="Sistema Financeiro"

# Configurações de Cache
CACHE_ENABLED=true

# Configurações de Backup
BACKUP_ENABLED=true

# Configurações de CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Configurações de Log
LOG_LEVEL=info

# Configurações de API Externa (OpenExchangeRates para conversão de moedas)
EXCHANGE_RATE_API_KEY=your-api-key

# Configurações de Notificações Push
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Configurações de Armazenamento
STORAGE_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Configurações de Segurança
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data